# -----------------------------------------------------------------------------
# Public site
# -----------------------------------------------------------------------------

# Public base URL used by metadata, sitemap, robots, and canonical URLs.
# Example: https://mansvalve.kz
SITE_URL=https://example.com

# Optional but recommended: Google Tag Manager container ID (public, embedded in the client bundle).
# Example: GTM-XXXXXXX
# If empty: GTM is not loaded; client trackEvent() is a no-op (no dataLayer, no throws).
NEXT_PUBLIC_GTM_ID=

# Server-only Telegram credentials for POST /api/request delivery.
# Never expose these as NEXT_PUBLIC_* variables.
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_CHAT_ID=replace_with_real_chat_id

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# Connection string for the primary Postgres database that backs the admin
# panel. Recommended provider: Supabase (the built-in Postgres instance),
# but any Postgres >= 14 will work (local docker, Neon, RDS, etc.).
#
# Supabase: Project Settings -> Database -> Connection string -> URI (pooled).
# Local dev: postgres://postgres:postgres@localhost:5432/mansvalve
DATABASE_URL=

# Optional: when set to "true", Drizzle logs every SQL query (dev only).
DATABASE_LOG=false

# -----------------------------------------------------------------------------
# Admin auth
# -----------------------------------------------------------------------------
# Long random secret used to sign admin session JWTs.
# Generate with: openssl rand -base64 48   (or any 48+ byte random string)
ADMIN_SESSION_SECRET=

# Optional. Hours a session stays valid after login. Defaults to 12.
ADMIN_SESSION_TTL_HOURS=12

# Bootstrap credentials used by `npm run admin:create` to provision the first
# admin account if the admin_users table is empty. Leave blank in production
# once the real account has been created.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# -----------------------------------------------------------------------------
# Media storage
# -----------------------------------------------------------------------------
# Media driver. Supported values:
#   - "local"    - stores files under ./public/uploads (dev only)
#   - "supabase" - Supabase Storage bucket (prod)
MEDIA_DRIVER=local

# Supabase Storage config (required when MEDIA_DRIVER=supabase).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=mansvalve-media

# Public base URL used for rendering uploaded media on the site.
# For "local" driver this defaults to /uploads.
# For "supabase" this is typically https://<project>.supabase.co/storage/v1/object/public/<bucket>.
MEDIA_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Public catalog source selector:
#   - "json" (default): static generated catalog from data/catalog-products.json
#   - "db": read categories/products from Postgres admin tables
# Keep "json" until DB parity checks are complete.
PUBLIC_CATALOG_SOURCE=json

# Backward-compatible legacy switch. If set to "true" and
# PUBLIC_CATALOG_SOURCE is not set, DB source will be used.
PUBLIC_CATALOG_FROM_DB=false
